---
import { Mail, MessageCircle, Phone } from "@lucide/astro";
import ActionButton from "./ActionButton.astro";
import { business } from "../config/business";
import ResponsiveImage from "./ResponsiveImage.astro";
---

<section class="contact-section section-shell" id="contact">
  <div class="contact-panel">
    {
      business.profilePhoto && (
        <ResponsiveImage
          class="contact-panel__photo"
          src={business.profilePhoto}
          alt={business.owner || business.name}
          sizes="54px"
        />
      )
    }
    <div>
      <div class="section-label">
        {business.copy.contactEyebrow} {business.owner || business.name}
      </div>
      <h2>{business.copy.contactHeading}</h2>
      <p>{business.copy.contactText}</p>
    </div>
    <div class="contact-actions">
      {
        business.contact.actions.map((action) => (
          <ActionButton
            href={action.href}
            label={action.label}
            variant={action.primary ? "primary" : "light"}
            external={action.href.startsWith("http")}
          >
            {action.href.startsWith("tel:") ? (
              <Phone size={19} />
            ) : action.href.startsWith("mailto:") ? (
              <Mail size={19} />
            ) : (
              <MessageCircle size={19} />
            )}
          </ActionButton>
        ))
      }
    </div>
  </div>
</section>

<style>
  .section-shell {
    width: min(100% - 40px, 1040px);
    margin-inline: auto;
  }

  .section-label {
    margin-bottom: 5px;
    color: #b8dfcf;
    font-size: 0.75rem;
    font-weight: 850;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .contact-section {
    padding-block: 0 52px;
  }

  .contact-panel {
    padding: 28px 32px;
    border-radius: 8px;
    display: grid;
    grid-template-columns: 58px 1fr auto;
    align-items: center;
    gap: 24px;
    color: white;
    background: var(--secondary);
  }

  .contact-panel:not(:has(.contact-panel__photo)) {
    grid-template-columns: 1fr auto;
  }

  .contact-panel__photo {
    width: 54px;
    height: 54px;
    border: 3px solid #b8dfcf;
    border-radius: 50%;
    object-fit: cover;
  }

  h2 {
    margin: 0;
    font-size: 1.75rem;
    line-height: 1.12;
  }

  p {
    margin: 7px 0 0;
    color: #d0dfda;
    font-size: 0.9rem;
  }

  .contact-actions {
    min-width: 230px;
    display: grid;
    gap: 9px;
  }

  @media (max-width: 820px) {
    .contact-panel {
      padding: 24px 20px;
      grid-template-columns: 1fr;
      gap: 18px;
    }

    .contact-section {
      padding-block: 0 40px;
    }

    .contact-panel__photo {
      width: 46px;
      height: 46px;
    }

    .contact-actions {
      min-width: 0;
    }
  }
</style>

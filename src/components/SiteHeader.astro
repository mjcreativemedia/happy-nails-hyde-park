---
import { business } from "../config/business";
import { getProvenServiceAreas } from "../data/proofs";
import {
  locationsPath,
  proofArchivePath,
  servicesPath,
} from "../lib/urls";
import BrandIdentity from "./BrandIdentity.astro";

const hasLocations = getProvenServiceAreas().length > 0;
---

<header class="site-header">
  <a class="brand" href="/" aria-label={`${business.name} home`}>
    <BrandIdentity showName />
  </a>
  <nav aria-label="Primary navigation">
    <a href={proofArchivePath()}>{business.proof.labels.archive}</a>
    <a href={servicesPath()}>Services</a>
    {hasLocations && <a href={locationsPath()}>Locations</a>}
    <a href="/#contact">Contact</a>
  </nav>
</header>

<style>
  .site-header {
    min-height: 64px;
    padding-inline: max(20px, calc((100vw - 1060px) / 2));
    border-bottom: 1px solid var(--line);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 22px;
    background: var(--background);
  }

  .brand,
  nav a {
    color: var(--primary);
    font-weight: 850;
    text-decoration: none;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 10px;
  }

  nav {
    display: flex;
    gap: 22px;
    font-size: 0.9rem;
  }

  @media (max-width: 620px) {
    .brand span,
    nav a:nth-child(2) {
      display: none;
    }
  }
</style>

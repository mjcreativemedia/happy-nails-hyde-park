---
import { getOptimizedMedia } from "../lib/media";

interface Props {
  src: string;
  alt: string;
  sizes?: string;
  loading?: "eager" | "lazy";
  fetchpriority?: "high" | "low" | "auto";
  class?: string;
}

const {
  src,
  alt,
  sizes = "100vw",
  loading = "lazy",
  fetchpriority,
  class: className,
} = Astro.props;
const media = getOptimizedMedia(src);
const isVector = src.endsWith(".svg");
const isOptimizedWebp = src.endsWith(".webp");
if (!media && !isVector && !isOptimizedWebp) {
  throw new Error(`Missing optimized media manifest entry: ${src}`);
}
const srcset = (variants: { src: string; width: number }[]) =>
  variants.map((variant) => `${variant.src} ${variant.width}w`).join(", ");
---

{
  media ? (
    <picture>
      <source type="image/avif" srcset={srcset(media.avif)} sizes={sizes} />
      <source type="image/webp" srcset={srcset(media.webp)} sizes={sizes} />
      <img
        src={media.fallback}
        alt={alt}
        width={media.width}
        height={media.height}
        loading={loading}
        decoding="async"
        fetchpriority={fetchpriority}
        class={className}
      />
    </picture>
  ) : (
    <img
      src={src}
      alt={alt}
      loading={loading}
      decoding="async"
      fetchpriority={fetchpriority}
      class={className}
    />
  )
}

<style>
  picture {
    display: contents;
  }
</style>

---
import {
  ArrowRight,
  Mail,
  MapPin,
  MessageCircle,
  Phone,
} from "@lucide/astro";
import ActionButton from "../components/ActionButton.astro";
import BrandIdentity from "../components/BrandIdentity.astro";
import ContactSection from "../components/ContactSection.astro";
import ProofCard from "../components/ProofCard.astro";
import ResponsiveImage from "../components/ResponsiveImage.astro";
import { business } from "../config/business";
import {
  getFeaturedProofs,
  getProofCollections,
  getProvenServiceAreas,
  validateContent,
} from "../data/proofs";
import BaseLayout from "../layouts/BaseLayout.astro";
import { homepageSchema } from "../lib/schema";
import {
  locationPath,
  collectionPath,
  proofArchivePath,
  servicePath,
} from "../lib/urls";

validateContent();
const featuredProofs = getFeaturedProofs(business.proof.featuredLimit);
const collections = getProofCollections();
const provenAreas = getProvenServiceAreas();
const [primaryAction, secondaryAction] = business.contact.actions;
const specialties = business.hero.specialties.slice(0, 3).join(" · ");
const stars = business.hero.rating
  ? "★".repeat(Math.max(0, Math.min(5, business.hero.rating)))
  : "";
---

<BaseLayout
  seo={{
    title: `${business.name} | ${business.businessType}`,
    description: `${business.tagline} See curated ${business.proof.plural.toLowerCase()}, services, and direct contact information.`,
    canonical: "/",
    image: business.heroImage,
    jsonLd: homepageSchema(),
  }}
>
  <header class="site-header">
    <a class="brand" href="#top" aria-label={`${business.name} home`}>
      <BrandIdentity />
    </a>
    <a
      class="header-message"
      href={business.contact.headerActionHref}
      target={business.contact.headerActionHref.startsWith("http") ? "_blank" : undefined}
      rel={business.contact.headerActionHref.startsWith("http") ? "noreferrer" : undefined}
    >
      <MessageCircle size={17} />
      {business.contact.headerActionLabel}
    </a>
  </header>

  <main id="top">
    <section class="profile-hero">
      <div class="profile-hero__inner">
        <div class="hero-media">
          <ResponsiveImage
            src={business.heroImage}
            alt={`${business.name} documented work`}
            sizes="(max-width: 720px) calc(100vw - 40px), 380px"
            loading="eager"
            fetchpriority="high"
          />
        </div>

        <div class="profile-copy">
          <div class="eyebrow">{business.businessType}</div>
          <h1>{business.name}</h1>
          <p class="location"><MapPin size={17} /> {business.location}</p>
          <p class="services-line">{specialties}</p>

          {
            business.hero.trustText && (
              <div class="trust-line">
                {
                  business.hero.rating && (
                    <span class="stars" aria-label={`${business.hero.rating} stars`}>
                      {stars}
                    </span>
                  )
                }
                <span>{business.hero.trustText}</span>
              </div>
            )
          }

          <div class="profile-actions">
            {
              primaryAction && (
                <ActionButton
                  href={primaryAction.href}
                  label={primaryAction.label}
                  variant="primary"
                  external={primaryAction.href.startsWith("http")}
                >
                  {primaryAction.href.startsWith("tel:") ? (
                    <Phone size={19} />
                  ) : primaryAction.href.startsWith("mailto:") ? (
                    <Mail size={19} />
                  ) : (
                    <MessageCircle size={19} />
                  )}
                </ActionButton>
              )
            }
            {
              secondaryAction && (
                <ActionButton
                  href={secondaryAction.href}
                  label={secondaryAction.label}
                  variant="secondary"
                  external={secondaryAction.href.startsWith("http")}
                >
                  {secondaryAction.href.startsWith("tel:") ? (
                    <Phone size={19} />
                  ) : secondaryAction.href.startsWith("mailto:") ? (
                    <Mail size={19} />
                  ) : (
                    <MessageCircle size={19} />
                  )}
                </ActionButton>
              )
            }
          </div>
        </div>
      </div>
    </section>

    <section class="work-section" id="featured-work">
      <div class="section-shell section-heading">
        <div class="section-label">{business.proof.labels.featured}</div>
        <h2>Pick a color. Find a detail. Save your favorite.</h2>
        <div class="collection-links" aria-label="Design collections">
          {collections.map((collection) => (
            <a href={collectionPath(collection.slug)}>{collection.tag}</a>
          ))}
        </div>
      </div>

      <div class="proof-grid section-shell">
        {
          featuredProofs.map((proof) => (
            <ProofCard proof={proof} videoBehavior="viewport" />
          ))
        }
      </div>

      <div class="work-footer section-shell">
        <a href={proofArchivePath()}>
          View {business.proof.labels.archive} <ArrowRight size={18} />
        </a>
      </div>
    </section>

    <section class="reference-section section-shell">
      <div class="reference-sheet">
        <div class="reference-services">
          <div class="section-label">{business.copy.servicesEyebrow}</div>
          <div class="service-list" aria-label={`${business.name} services`}>
            {
              business.services.map((service) => (
                <a class="service-row" href={servicePath(service.slug)}>
                  <span class="service-row__media">
                    <ResponsiveImage src={service.image} alt="" sizes="84px" />
                  </span>
                  <strong>{service.title}</strong>
                </a>
              ))
            }
          </div>
        </div>

        {
          business.serviceAreas.length > 0 && (
            <div class="reference-area">
              <div class="section-label">{business.copy.coverageEyebrow}</div>
              <div class="area-list" aria-label={`${business.name} service area`}>
                {
                  business.serviceAreas.map((area) => {
                    const hasProof = provenAreas.some(
                      (candidate) => candidate.slug === area.slug,
                    );
                    return hasProof ? (
                      <a href={locationPath(area.slug)}>{area.name}</a>
                    ) : (
                      <span>{area.name}</span>
                    );
                  })
                }
              </div>
            </div>
          )
        }
      </div>
    </section>

    <ContactSection />
  </main>

  <footer><span>{business.location}</span></footer>
</BaseLayout>

<style>
  .site-header {
    height: 64px;
    padding: 0 max(20px, calc((100vw - 1120px) / 2));
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-bottom: 1px solid var(--line);
    background: color-mix(in srgb, var(--background) 94%, transparent);
    backdrop-filter: blur(12px);
    position: sticky;
    top: 0;
    z-index: 10;
  }

  .brand,
  .header-message {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    color: var(--primary);
    font-size: 0.93rem;
    font-weight: 800;
    text-decoration: none;
  }

  .header-message {
    font-size: 0.85rem;
  }

  .section-shell {
    width: min(100% - 40px, 1040px);
    margin-inline: auto;
  }

  .profile-hero {
    overflow: hidden;
    background: var(--primary);
  }

  .profile-hero__inner {
    width: min(100% - 40px, 1040px);
    min-height: 430px;
    margin-inline: auto;
    padding: 30px 0 24px;
    display: grid;
    grid-template-columns: minmax(260px, 380px) 1fr;
    align-content: center;
    align-items: center;
    gap: 22px 32px;
    color: white;
    position: relative;
  }

  .hero-media {
    width: 100%;
    max-height: 520px;
    overflow: hidden;
    aspect-ratio: 4 / 5;
    border-radius: 12px;
    box-shadow: var(--shadow);
  }

  .hero-media :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .eyebrow,
  .section-label {
    margin-bottom: 8px;
    color: var(--accent);
    font-size: 0.75rem;
    font-weight: 850;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .profile-copy h1 {
    max-width: 620px;
    margin: 0;
    font-size: clamp(2.45rem, 6vw, 4.5rem);
    line-height: 0.98;
    letter-spacing: 0;
  }

  .location {
    margin: 18px 0 5px;
    display: flex;
    align-items: center;
    gap: 6px;
    font-weight: 700;
  }

  .services-line {
    margin: 0;
    color: #d4e2dd;
    font-size: 0.95rem;
  }

  .trust-line {
    margin-top: 18px;
    display: flex;
    align-items: center;
    gap: 10px;
    color: #e5ece9;
    font-size: 0.87rem;
  }

  .stars {
    color: #ffc15e;
  }

  .profile-actions {
    margin-top: 22px;
    display: grid;
    grid-template-columns: repeat(2, minmax(150px, 190px));
    gap: 10px;
  }

  .work-section {
    padding-block: 46px 50px;
    border-block: 1px solid var(--line);
    background: #edf1ed;
  }

  .section-heading {
    margin-bottom: 22px;
  }

  .section-heading h2 {
    max-width: 720px;
    margin: 0;
    font-size: clamp(2rem, 4.8vw, 3.8rem);
    line-height: 1;
    letter-spacing: -0.045em;
  }

  .collection-links {
    margin-top: 22px;
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .collection-links a {
    padding: 8px 12px;
    border: 1px solid #ccd8d0;
    border-radius: 999px;
    color: var(--primary);
    background: rgba(255, 255, 255, 0.72);
    font-size: 0.78rem;
    font-weight: 800;
    text-decoration: none;
  }

  .proof-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 18px;
  }

  .work-footer {
    margin-top: 34px;
    display: flex;
  }

  .work-footer a {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    color: var(--primary);
    font-weight: 850;
    text-decoration: none;
  }

  .reference-section {
    padding-block: 42px 28px;
  }

  .reference-sheet {
    padding: 30px;
    border: 1px solid #d4dcd6;
    border-radius: 8px;
    display: grid;
    grid-template-columns: 1.45fr 0.55fr;
    gap: 32px;
    background: white;
    box-shadow: 0 10px 30px rgba(24, 44, 38, 0.06);
  }

  .service-list {
    margin-top: 18px;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 12px;
  }

  .service-row {
    min-width: 0;
    overflow: hidden;
    border: 1px solid #dde4df;
    border-radius: 8px;
    display: grid;
    grid-template-columns: 84px minmax(0, 1fr);
    align-items: center;
    gap: 14px;
    background: #f8faf8;
    color: inherit;
    text-decoration: none;
  }

  .service-row__media {
    width: 84px;
    height: 76px;
    overflow: hidden;
    background: var(--soft);
  }

  .service-row__media :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .service-row strong {
    padding-right: 12px;
    font-size: 0.9rem;
    line-height: 1.2;
  }

  .reference-area {
    padding-left: 28px;
    border-left: 1px solid #dfe5e0;
  }

  .area-list {
    margin-top: 18px;
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .area-list span,
  .area-list a {
    padding: 8px 11px;
    border: 1px solid #d6e2dc;
    border-radius: 999px;
    color: var(--secondary);
    background: #f1f6f3;
    font-size: 0.82rem;
    font-weight: 750;
    text-decoration: none;
  }

  footer {
    min-height: 48px;
    padding-inline: max(20px, calc((100vw - 1040px) / 2));
    border-top: 1px solid var(--line);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--muted);
    font-size: 0.75rem;
  }

  @media (max-width: 820px) {
    .site-header {
      height: 58px;
    }

    .profile-hero__inner {
      min-height: 0;
      padding: 36px 0 24px;
      grid-template-columns: minmax(200px, 300px) minmax(0, 1fr);
      align-content: start;
      gap: 20px 28px;
    }

    .hero-media {
      max-height: 420px;
    }

    .profile-copy h1 {
      font-size: clamp(2.5rem, 7vw, 3.5rem);
    }

    .eyebrow {
      margin-bottom: 4px;
      font-size: 0.7rem;
    }

    .location {
      margin-top: 14px;
      font-size: 0.94rem;
    }

    .services-line {
      font-size: 0.88rem;
    }

    .trust-line {
      margin-top: 14px;
      font-size: 0.85rem;
    }

    .profile-actions {
      grid-column: 1 / -1;
      margin-top: 16px;
      grid-template-columns: 1fr;
      max-width: none;
    }

    .work-section {
      padding-block: 40px 44px;
    }

    .proof-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 16px;
    }

    .reference-section {
      padding-block: 32px 24px;
    }

    .reference-sheet {
      padding: 24px 20px;
      grid-template-columns: 1fr;
      gap: 24px;
    }

    .reference-area {
      padding: 22px 0 0;
      border-top: 1px solid #dfe5e0;
      border-left: 0;
    }

    .service-list {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 10px;
    }

    .service-row {
      grid-template-columns: 1fr;
      gap: 0;
    }

    .service-row__media {
      width: 100%;
      height: 104px;
    }

    .service-row strong {
      min-height: 48px;
      padding: 10px 9px;
      display: flex;
      align-items: center;
      font-size: 0.86rem;
    }
  }

  @media (max-width: 560px) {
    .profile-hero__inner {
      width: min(100% - 32px, 1040px);
      padding-top: 28px;
      grid-template-columns: 1fr;
      justify-items: start;
      align-items: center;
      gap: 14px;
      text-align: left;
    }

    .hero-media {
      width: min(78vw, 320px);
      max-height: 400px;
    }

    .profile-copy {
      width: 100%;
    }

    .profile-copy h1 {
      max-width: none;
      font-size: 2rem;
      line-height: 1.02;
    }

    .location {
      margin-top: 9px;
      justify-content: flex-start;
      font-size: 0.8rem;
    }

    .services-line {
      font-size: 0.72rem;
    }

    .trust-line {
      justify-content: flex-start;
      margin-top: 10px;
      font-size: 0.74rem;
    }

    .profile-actions {
      grid-column: 1 / -1;
      margin-top: 18px;
      max-width: none;
      grid-template-columns: 1fr;
    }

    .proof-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
